[flake8]
max-line-length = 88
# E203 — whitespace before ':' — black produces this in slice notation.
# W503 — line break before binary operator — black style.
# E501 — line too long — black enforces 88 chars in code; docstrings and
#          comments are left untouched by black and may exceed 88 chars.
extend-ignore = E203, W503, E501

per-file-ignores =
    # print() is intentional in __main__ demo blocks
    scatterbrain/core.py: T201
    scatterbrain/modeling/form_factors.py: T201
    # example scripts intentionally use print() and may have loose imports
    scatterbrain/examples/*.py: T201, F401
    # matplotlib.use('Agg') must precede other imports — E402 is expected
    tests/test_visualization.py: E402

exclude =
    .git,
    .venv,
    __pycache__,
    *.egg-info,
    build,
    dist,
    docs,
    notebooks,
